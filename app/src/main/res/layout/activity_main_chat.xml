<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#0A0A0A">

    <!-- Top Navigation Bar (Premium Glass) -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:background="#11FFFFFF"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="313dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:letterSpacing="0.2"
            android:text="Δ 👾 ∇        GHOST"
            android:textColor="@color/accent_purple"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnMinimize"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="▼"
            android:textSize="18sp"
            android:textColor="@color/text_secondary"
            android:alpha="0.6"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <!-- Chat History List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toTopOf="@id/inputBar" />

    <!-- Loading Indicator (Futuristic) -->
    <ProgressBar
        android:id="@+id/thinkingProgress"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="12dp"
        android:visibility="gone"
        android:indeterminateTint="@color/accent_purple"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/visualizer" />

    <TextView
        android:id="@+id/thinkingText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="Thinking..."
        android:textColor="@color/accent_purple"
        android:textSize="10sp"
        android:letterSpacing="0.05"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/thinkingProgress"
        app:layout_constraintStart_toEndOf="@id/thinkingProgress"
        app:layout_constraintTop_toTopOf="@id/thinkingProgress" />

    <!-- Audio Visualizer -->
    <com.ghost.api.ui.AudioVisualizerView
        android:id="@+id/visualizer"
        android:layout_width="100dp"
        android:layout_height="30dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/inputBar" />

    <!-- Input Bar Area (Premium Pill) -->
    <LinearLayout
        android:id="@+id/inputBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="20dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:background="@drawable/input_pill_bg"
        android:gravity="center_vertical"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/btnSparkle"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="✧"
            android:textSize="26sp"
            android:textColor="#A78BFA"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless" />

        <EditText
            android:id="@+id/chatInputText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Δ 👾 ∇"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="5"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="#44FFFFFF"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/btnMic"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:text="🟣"
            android:alpha="0.8"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/btnSend"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:text="➤"
            android:textColor="#A78BFA"
            android:textSize="22sp"
            android:visibility="gone" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
