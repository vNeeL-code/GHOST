<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/messageContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- Message Bubble -->
    <LinearLayout
        android:id="@+id/bubbleLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/chat_bubble_bg"
        android:elevation="2dp"
        android:maxWidth="320dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/textHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Δ ✧ ∇"
                android:textColor="@color/accent_purple"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textIsSelectable="true" />

            <ImageButton
                android:id="@+id/btnCopy"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_save"
                android:contentDescription="Copy Message"
                android:alpha="0.4"
                android:scaleType="centerInside" />
        </LinearLayout>

        <!-- Premium Thinking Block -->
        <LinearLayout
            android:id="@+id/layoutThinking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="#11FFFFFF"
            android:padding="10dp"
            android:layout_marginBottom="10dp"
            android:alpha="0.8">
            
            <TextView
                android:id="@+id/btnToggleThinking"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="reasoning ▸"
                android:textSize="10sp"
                android:textColor="#88FFFFFF"
                android:letterSpacing="0.05"
                android:background="?android:attr/selectableItemBackground"/>
                
            <TextView
                android:id="@+id/textThinking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#99FFFFFF"
                android:visibility="gone"
                android:paddingTop="6dp"
                android:lineSpacingExtra="2dp"
                android:textIsSelectable="true"/>
        </LinearLayout>

        <TextView
            android:id="@+id/textMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:textIsSelectable="true"/>

        <!-- Interactive WebView for Skills/Games -->
        <WebView
            android:id="@+id/skillWebView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            android:background="#00000000" />

    </LinearLayout>

    <TextView
        android:id="@+id/textTimestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textSize="9sp"
        android:alpha="0.5"
        android:textColor="@color/text_secondary"
        android:textIsSelectable="true"
        android:visibility="visible" />
</LinearLayout>
